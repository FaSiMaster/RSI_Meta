# Admin-Schlüssel für geschützte API-Endpunkte
# Vor dem Start in .env.local kopieren und eigenen Wert setzen:
# cp .env.example .env.local
ADMIN_KEY=rsi-admin-changeme

# Erlaubte Herkunft für CORS (Production)
# Für Vercel-Deployment anpassen:
ALLOWED_ORIGIN=https://rsi-meta.vercel.app

# Node-Umgebung (wird automatisch gesetzt)
# NODE_ENV=development
